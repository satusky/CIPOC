      "behaviors": null,
      "sex": null,
      "dx_date_min": "2000-01-01",
      "dx_date_max": null
    },
    "text": "Use code 0 when the patient has metastasis to lung and liver but not brain.",
    "codes": null,
    "notes": null
  },
  {
