    },
    "text": "| Code | Description |\n|---|---|\n| 0 | None; no brain metastases |\n| 1 | Yes; distant brain metastases |\n| 8 | Not applicable |\n| 9 | Unknown whether brain is involved metastatic site Not documented in patient record |",
    "codes": {
      "0": "None; no brain metastases",
      "1": "Yes; distant brain metastases",
      "8": "Not applicable",
