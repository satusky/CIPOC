      "behaviors": null,
      "sex": null,
      "dx_date_min": "2000-01-01",
      "dx_date_max": null
    },
    "text": "Use of codes. Assign the code that best describes whether the case has brain metastases at diagnosis.",
    "codes": null,
    "notes": null
  },
  {
    "rule_id": "spcsm_2024:mets_brain:coding_instructions:i8",
