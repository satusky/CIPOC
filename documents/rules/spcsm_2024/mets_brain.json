      "histologies": null,
      "behaviors": null,
      "sex": null,
      "dx_date_min": "2000-01-01",
      "dx_date_max": null
    },
    "text": "Use code 0 when the medical record indicates that there are no distant (discontinuous) metastases at all; confirms the tumor is benign (/0), borderline (/1), or in situ (/2); includes a clinical or pathologic statement that there are no brain metastases; includes imaging reports that are negative for brain metastases; or indicates that the patient has distant (discontinuous) metastases but brain is not mentioned as an involved site.",
    "codes": null,
    "notes": null
  },
  {
    "rule_id": "spcsm_2024:mets_brain:coding_instructions:e9",
