    },
    "text": "This data item identifies whether bone is an involved metastatic site.",
    "codes": null,
    "notes": null
  },
  {
    "rule_id": "spcsm_2024:mets_bone:mets_at_diagnosisbone:t2",
    "source_doc": "spcsm_2024",
    "section_path": [
      "Section VI Stage-related Data Items",
