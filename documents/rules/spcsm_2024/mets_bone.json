    "item_ids": [
      1112
    ],
    "applies_to": {
      "sites": [
        "C420",
        "C421",
        "C423",
        "C424"
      ],
      "histologies": null,
      "behaviors": null,
      "sex": null,
      "dx_date_min": "2000-01-01",
      "dx_date_max": null
    },
    "text": "Use code 8 (Not applicable) for the following i. Any case coded to primary site C420, C421, C423, or C424.",
    "codes": null,
    "notes": null
  },
  {
    "rule_id": "spcsm_2024:mets_bone:coding_instructions:i12",
    "source_doc": "spcsm_2024",
    "section_path": [
      "Section VI Stage-related Data Items",
      "Mets at Diagnosis--Bone",
      "Coding Instructions"
    ],
    "anchor": "L4123-L4175:coding-instructions",
