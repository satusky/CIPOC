      "sex": null,
      "dx_date_min": "2000-01-01",
      "dx_date_max": null
    },
    "text": "Use code 8 (Not applicable) for the following ii. Plasma Cell Disorders 00822.",
    "codes": null,
    "notes": null
  },
  {
    "rule_id": "spcsm_2024:mets_bone:coding_instructions:i13",
    "source_doc": "spcsm_2024",
    "section_path": [
