      "behaviors": null,
      "sex": null,
      "dx_date_min": "2000-01-01",
      "dx_date_max": null
    },
    "text": "Bone involvement may be single or multiple.",
    "codes": null,
    "notes": null
  },
  {
    "rule_id": "spcsm_2024:mets_bone:coding_instructions:i3",
    "source_doc": "spcsm_2024",
