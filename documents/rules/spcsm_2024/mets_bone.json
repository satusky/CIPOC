      "sex": null,
      "dx_date_min": "2000-01-01",
      "dx_date_max": null
    },
    "text": "Information about bone involvement may be clinical or pathological.",
    "codes": null,
    "notes": null
  },
  {
    "rule_id": "spcsm_2024:mets_bone:coding_instructions:i4",
    "source_doc": "spcsm_2024",
