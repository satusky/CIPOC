    "item_ids": [
      1112
    ],
    "applies_to": {
      "sites": null,
      "histologies": null,
      "behaviors": null,
      "sex": null,
      "dx_date_min": "2000-01-01",
      "dx_date_max": null
    },
    "text": "| Code | Description |\n|---|---|\n| 0 | None; no bone metastases |\n| 1 | Yes; distant bone metastases |\n| 8 | Not applicable |\n| 9 | Unknown whether bone is an involved metastatic site Not documented in patient record |",
    "codes": {
      "0": "None; no bone metastases",
      "1": "Yes; distant bone metastases",
      "8": "Not applicable",
      "9": "Unknown whether bone is an involved metastatic site Not documented in patient record"
    },
    "notes": null
  },
  {
    "rule_id": "spcsm_2024:mets_bone:coding_instructions:i1",
    "source_doc": "spcsm_2024",
    "section_path": [
      "Section VI Stage-related Data Items",
