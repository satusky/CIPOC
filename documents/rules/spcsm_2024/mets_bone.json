    ],
    "anchor": "L4123-L4175:coding-instructions",
    "kind": "instruction",
    "item_ids": [
      1112
    ],
    "applies_to": {
      "sites": null,
      "histologies": null,
      "behaviors": null,
      "sex": null,
      "dx_date_min": "2000-01-01",
      "dx_date_max": null
    },
    "text": "Code information about bone metastases only (discontinuous or distant metastases to bone) identified at the time of diagnosis. Do not code bone marrow involvement in this data item. Do not record contiguous bone invasion by primary tumor in this data item. Note: See code 1 in \"Mets at Diagnosis--Other\" for bone marrow involvement.",
    "codes": null,
    "notes": null
  },
  {
